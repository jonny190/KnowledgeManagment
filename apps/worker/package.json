{
  "name": "@km/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "dotenv -e ../../.env -- vitest run --passWithNoTests"
  },
  "dependencies": {
    "@km/db": "workspace:*",
    "@km/email": "workspace:*",
    "@km/shared": "workspace:*",
    "archiver": "7.0.1",
    "pg-boss": "9.0.3"
  },
  "devDependencies": {
    "@types/archiver": "6.0.2",
    "dotenv-cli": "7.4.2",
    "tsx": "4.19.1",
    "typescript": "5.5.4",
    "vitest": "2.1.2"
  }
}
